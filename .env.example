# ---- App ----
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000
APP_CORS_ORIGINS=["http://localhost:3000"]

# ---- Postgres ----
# NOTE: POSTGRES_PASSWORD below is a placeholder for local dev only.
# Generate a real value before any non-local deployment, e.g.:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
POSTGRES_USER=tdp_app
POSTGRES_PASSWORD=replace-with-local-dev-secret
POSTGRES_DB=tdp
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Keep DATABASE_URL in sync with the values above.
DATABASE_URL=postgresql+asyncpg://tdp_app:replace-with-local-dev-secret@postgres:5432/tdp
DATABASE_SYNC_URL=postgresql+psycopg://tdp_app:replace-with-local-dev-secret@postgres:5432/tdp

# ---- Redis ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- GTFS ----
# TransLink SEQ feeds (public, no auth)
GTFS_STATIC_URL=https://gtfsrt.api.translink.com.au/GTFS/SEQ_GTFS.zip
GTFS_RT_TRIP_UPDATES_URL=https://gtfsrt.api.translink.com.au/api/realtime/SEQ/TripUpdates
GTFS_RT_VEHICLE_POSITIONS_URL=https://gtfsrt.api.translink.com.au/api/realtime/SEQ/VehiclePositions
GTFS_RT_ALERTS_URL=https://gtfsrt.api.translink.com.au/api/realtime/SEQ/Alerts

# Poll cadence (seconds)
GTFS_RT_POLL_INTERVAL=60
GTFS_STATIC_REFRESH_HOURS=24

# ---- Predictor ----
PREDICTOR_HISTORY_DAYS=14
PREDICTOR_MIN_OBSERVATIONS=5
PREDICTOR_CACHE_TTL_SECONDS=60

# ---- BOM weather (SEQ stations: 94576=Brisbane, 94578=Brisbane Airport) ----
BOM_STATION_IDS=["94576","94578"]
BOM_USER_AGENT=transport-delay-predictor/0.1 (+https://github.com/proteek-dev/Transport-Delay-Predictor)
BOM_POLL_INTERVAL_SECONDS=1800

# ---- Public holidays ----
NAGER_HOLIDAYS_URL=https://date.nager.at/api/v3

# ---- Feature pipeline ----
FEATURE_WINDOW_DAYS=30
FEATURE_REBUILD_INTERVAL_SECONDS=21600

# ---- ML model (XGBoost delay predictor) ----
MODEL_ARTIFACT_PATH=/srv/models/delay_predictor.joblib
MODEL_TRAINING_WINDOW_DAYS=30
MODEL_MIN_TRAINING_SAMPLES=200
MODEL_TEST_SIZE=0.2
MODEL_N_ESTIMATORS=400
MODEL_MAX_DEPTH=6
MODEL_LEARNING_RATE=0.05
MODEL_RETRAIN_HOUR_UTC=2
MODEL_RETRAIN_MINUTE_UTC=30
